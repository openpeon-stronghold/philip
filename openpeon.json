{
  "cesp_version": "1.0",
  "name": "stronghold-philip",
  "display_name": "King Philip (Stronghold Crusader)",
  "version": "1.0.0",
  "author": { "name": "Marko Jevic", "github": "koyev" },
  "license": "fair-use",
  "language": "en",
  "categories": {
    "session.start": {
      "sounds": [
        { "file": "sounds/ph_add_player_01.wav", "label": "Mais oui" }
      ]
    },
    "task.acknowledge": {
      "sounds": [
        { "file": "sounds/ph_willattack_01.wav", "label": "On my honor" },
        { "file": "sounds/ph_sent_01.wav", "label": "Request has been dealt with" },
        { "file": "sounds/ph_siege_01.wav", "label": "Noblemen adorning armor" }
      ]
    },
    "task.complete": {
      "sounds": [
        { "file": "sounds/ph_vict_01.wav", "label": "Armies of France triumphant" },
        { "file": "sounds/ph_vict_02.wav", "label": "Quel courage!" },
        { "file": "sounds/ph_boast_01.wav", "label": "Dispatched another enemy" }
      ]
    },
    "task.error": {
      "sounds": [
        { "file": "sounds/ph_anger_01.wav", "label": "Surrounded by fools" },
        { "file": "sounds/ph_anger_02.wav", "label": "Black-hearted enemy" }
      ]
    },
    "input.required": {
      "sounds": [
        { "file": "sounds/ph_help_01.wav", "label": "Send your armies" },
        { "file": "sounds/ph_req_01.wav", "label": "Short of supplies" }
      ]
    },
    "resource.limit": {
      "sounds": [
        { "file": "sounds/ph_notsent_01.wav", "label": "Need these myself" },
        { "file": "sounds/ph_nohelp_01.wav", "label": "My knights are all dead" }
      ]
    },
    "user.spam": {
      "sounds": [
        { "file": "sounds/ph_noattack_02.wav", "label": "Too boring, don't bother me" },
        { "file": "sounds/ph_kick_player_01.wav", "label": "Adieu" }
      ]
    }
  }
}
